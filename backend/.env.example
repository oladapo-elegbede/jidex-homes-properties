# ============================================
# Jidex Homes & Properties — Backend Environment
# ============================================
# Copy this file to .env and fill in real values
# NEVER commit .env to Git
# ============================================

# Application Settings
APP_NAME="Jidex Homes & Properties"
APP_ENV=development
DEBUG=True

# Database Connection
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/jidex_db

# JWT Authentication
SECRET_KEY=your-very-long-random-secret-key-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS — comma-separated allowed origins (where the frontend will run)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# First Admin Account (created automatically on app startup)
FIRST_ADMIN_EMAIL=admin@jidexhomes.com
FIRST_ADMIN_PASSWORD=ChangeMe123!
FIRST_ADMIN_NAME=Platform Admin